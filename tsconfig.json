{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "rootDir": "src/scripts",
    "outDir": "dist/scripts",
    "strict": true,
    "noEmitOnError": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    /* ⚡ Production Performance & Code Optimization ⚡ */
    "removeComments": true,                     
    "sourceMap": false,                          
    "noUnusedLocals": true,                      
    "noUnusedParameters": true,                  
    "allowUnreachableCode": false                
  },
  "include": ["src/scripts/**/*.ts"]
}